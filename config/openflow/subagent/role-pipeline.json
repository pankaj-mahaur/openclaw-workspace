{
  "meta": {
    "name": "of-guard-role-pipeline",
    "version": "1.0.0",
    "updatedAt": "2026-03-03T10:26:00Z"
  },
  "orchestrator": {
    "owner": "Paplu",
    "executionMode": "run-based-subagents",
    "notes": [
      "Each role runs as a short task and hands off output to next role.",
      "Subagent sessions are run-mode in webchat context.",
      "OF-Guard key pool + rate-gate remains active for backend model routing."
    ]
  },
  "roles": [
    {
      "id": "search-engine",
      "label": "Search Engine",
      "job": "Find latest and relevant links from trusted sources only",
      "preferredModels": [
        "meta-llama/llama-4-scout-17b-16e-instruct",
        "qwen/qwen3-32b",
        "moonshotai/kimi-k2-instruct-0905"
      ],
      "outputContract": {
        "maxLinks": 15,
        "fields": [
          "title",
          "url",
          "reason",
          "freshness"
        ]
      }
    },
    {
      "id": "web-crawler",
      "label": "Web Crawler",
      "job": "Open trusted links and extract factual structured data",
      "preferredModels": [
        "llama-3.3-70b-versatile",
        "meta-llama/llama-4-scout-17b-16e-instruct",
        "openai/gpt-oss-120b"
      ],
      "outputContract": {
        "fields": [
          "topic",
          "fact",
          "value_or_date",
          "source_url"
        ],
        "mustInclude": [
          "conflicts",
          "unknowns"
        ]
      }
    },
    {
      "id": "summarizer",
      "label": "Summarizer",
      "job": "Convert crawled facts into question-focused brief",
      "preferredModels": [
        "meta-llama/llama-4-maverick-17b-128e-instruct",
        "moonshotai/kimi-k2-instruct-0905",
        "openai/gpt-oss-120b"
      ],
      "outputContract": {
        "sections": [
          "executive_summary",
          "key_takeaways",
          "risks_unknowns",
          "source_shortlist"
        ]
      }
    }
  ]
}
